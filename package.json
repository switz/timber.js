{
  "name": "timber-js",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @timber/app run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:blog": "playwright test --config examples/blog/playwright.config.ts",
    "test:e2e:tailwind": "playwright test --config examples/tailwind/playwright.config.ts",
    "test:e2e:kitchen-sink": "playwright test --config examples/kitchen-sink/playwright.config.ts",
    "typecheck": "tsgo --noEmit",
    "lint": "eslint",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "@content-collections/core": "^0.14.2",
    "@content-collections/mdx": "^0.2.2",
    "@content-collections/vite": "^0.2.9",
    "@mdx-js/rollup": "^3.1.1",
    "@playwright/test": "^1.58.2",
    "@switz/eslint-config": "^12.5.2",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-hooks": "^8.0.1",
    "@types/node": "^25.4.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260310.1",
    "@vitejs/plugin-rsc": "^0.5.19",
    "acorn": "^8.16.0",
    "acorn-jsx": "^5.3.2",
    "eslint": "^9.39.4",
    "happy-dom": "^20.8.3",
    "next-intl": "^4.8.3",
    "nuqs": "2.8.9",
    "oxfmt": "^0.37.0",
    "playwright": "^1.52.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "next",
        "webpack"
      ]
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
