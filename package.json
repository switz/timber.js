{
  "name": "timber-js",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @timber/app run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:blog": "playwright test --config examples/blog/playwright.config.ts",
    "test:e2e:tailwind": "playwright test --config examples/tailwind/playwright.config.ts",
    "test:e2e:kitchen-sink": "playwright test --config examples/kitchen-sink/playwright.config.ts",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint -c oxlint.json",
    "bench": "node benchmarks/run.js",
    "bench:json": "node benchmarks/run.js --json"
  },
  "devDependencies": {
    "@content-collections/core": "^0.14.2",
    "@content-collections/mdx": "^0.2.2",
    "@content-collections/vite": "^0.2.9",
    "@mdx-js/rollup": "^3.1.1",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.6.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@playwright/test": "^1.58.2",
    "@switz/eslint-config": "^13.0.0",
    "@testing-library/react": "^16.3.2",
    "@testing-library/react-hooks": "^8.0.1",
    "@types/node": "^25.4.0",
    "@types/prompts": "^2.4.9",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "7.0.0-dev.20260311.1",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitejs/plugin-rsc": "^0.5.21",
    "acorn": "^8.16.0",
    "acorn-jsx": "^5.3.2",
    "happy-dom": "^20.8.3",
    "next-intl": "^4.8.3",
    "nuqs": "2.8.9",
    "oxfmt": "^0.38.0",
    "oxlint": "^1.53.0",
    "playwright": "^1.52.0",
    "prompts": "^2.4.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-refresh": "^0.18.0",
    "typescript": "^5.9.3",
    "valibot": "^1.2.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  },
  "packageManager": "pnpm@10.32.1",
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "next",
        "webpack"
      ]
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ],
    "overrides": {
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "esbuild": "^0.27.0"
    }
  }
}
