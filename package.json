{
  "name": "timber-js",
  "private": true,
  "scripts": {
    "build": "pnpm --filter @timber/app run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "typecheck": "tsgo --noEmit",
    "lint": "oxlint --deny-warnings",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript/native-preview": "^7.0.0-dev.20260213.1",
    "@vitejs/plugin-rsc": "^0.5.19",
    "oxfmt": "^0.36.0",
    "oxlint": "^1.47.0",
    "playwright": "^1.52.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.7.0",
    "vite": "^7.3.1",
    "vitest": "^4.0.18"
  },
  "packageManager": "pnpm@10.30.0",
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "next",
        "webpack"
      ]
    },
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}
