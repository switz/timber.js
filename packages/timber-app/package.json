{
  "name": "@timber/app",
  "version": "0.1.0",
  "description": "Vite-native React framework for Cloudflare Workers — correct HTTP semantics, real status codes, pages that work without JavaScript",
  "type": "module",
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/switz/timber.js.git",
    "directory": "packages/timber-app"
  },
  "homepage": "https://github.com/switz/timber.js",
  "keywords": [
    "react",
    "vite",
    "rsc",
    "react-server-components",
    "cloudflare-workers",
    "framework",
    "ssr",
    "streaming"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "bin": {
    "timber": "./bin/timber.mjs"
  },
  "imports": {
    "#/*": "./src/*"
  },
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server/index.ts",
    "./client": "./src/client/index.ts",
    "./cache": "./src/cache/index.ts",
    "./content": "./src/content/index.ts",
    "./cookies": "./src/cookies/index.ts",
    "./search-params": "./src/search-params/index.ts",
    "./routing": "./src/routing/index.ts",
    "./adapters/cloudflare": "./src/adapters/cloudflare.ts",
    "./adapters/nitro": "./src/adapters/nitro.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "bin": {
      "timber": "./bin/timber.mjs"
    },
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./server": {
        "types": "./dist/server/index.d.ts",
        "import": "./dist/server/index.js"
      },
      "./client": {
        "types": "./dist/client/index.d.ts",
        "import": "./dist/client/index.js"
      },
      "./cache": {
        "types": "./dist/cache/index.d.ts",
        "import": "./dist/cache/index.js"
      },
      "./content": {
        "types": "./dist/content/index.d.ts",
        "import": "./dist/content/index.js"
      },
      "./cookies": {
        "types": "./dist/cookies/index.d.ts",
        "import": "./dist/cookies/index.js"
      },
      "./search-params": {
        "types": "./dist/search-params/index.d.ts",
        "import": "./dist/search-params/index.js"
      },
      "./routing": {
        "types": "./dist/routing/index.d.ts",
        "import": "./dist/routing/index.js"
      },
      "./adapters/cloudflare": {
        "types": "./dist/adapters/cloudflare.d.ts",
        "import": "./dist/adapters/cloudflare.js"
      },
      "./adapters/nitro": {
        "types": "./dist/adapters/nitro.d.ts",
        "import": "./dist/adapters/nitro.js"
      },
      "./package.json": "./package.json"
    }
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "vite build --config vite.lib.config.ts && tsc --emitDeclarationOnly --project tsconfig.json --outDir dist",
    "typecheck": "tsgo --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/context-async-hooks": "^2.6.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@vitejs/plugin-react": "^6.0.0",
    "@vitejs/plugin-rsc": "~0.5.21"
  },
  "peerDependencies": {
    "@content-collections/core": "^0.14.0",
    "@content-collections/mdx": "^0.2.0",
    "@content-collections/vite": "^0.2.0",
    "@mdx-js/rollup": "^3.0.0",
    "nuqs": "^2.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vite": "^8.0.0",
    "zod": "^3.22.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "@content-collections/core": {
      "optional": true
    },
    "@content-collections/mdx": {
      "optional": true
    },
    "@content-collections/vite": {
      "optional": true
    },
    "@mdx-js/rollup": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  }
}
