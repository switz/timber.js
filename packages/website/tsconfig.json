{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "rootDir": "../..",
    "types": ["vite/client"],
    "paths": {
      "content-collections": ["./.content-collections/generated"],
      "@timber/app": ["../timber-app/src/index.ts"],
      "@timber/app/*": ["../timber-app/src/*"]
    }
  },
  "include": [
    "app/**/*.ts",
    "app/**/*.tsx",
    "content-collections.ts",
    "mdx-components.tsx",
    ".content-collections/generated/**/*.ts",
  ]
}
